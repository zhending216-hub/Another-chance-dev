# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
Docs/todos_*.md
.cron/

# Execution cron
.cron/
.ops/

# Generated images (keep .gitkeep)
public/generated-images/*
!public/generated-images/.gitkeep

# Database backups
/backups/

# Prisma config (incompatible with current Prisma version)
prisma.config.ts
