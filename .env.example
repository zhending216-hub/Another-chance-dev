# ========================================
# 本地开发环境配置
# ========================================

# 数据库配置（本地开发使用 SQLite）
DATABASE_URL=file:./dev.db

# ========================================
# Docker 部署配置
# ========================================

# 数据库配置（Docker Compose 使用 PostgreSQL）
# DATABASE_URL=postgresql://gushi:gushi_dev@postgres:5432/gushi_dev

# ========================================
# AI API 配置（必填）
# ========================================

AI_API_KEY=your_ai_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4

# ========================================
# Next.js 配置
# ========================================

NEXT_TELEMETRY_DISABLED=1
NEXTAUTH_SECRET=your_nextauth_secret_here
AUTH_SECRET=your_auth_secret_here
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# ========================================
# 应用配置
# ========================================

APP_NAME=古事 - 分叉故事续写平台
APP_VERSION=1.0.0
APP_ENV=development

# ========================================
# AI 图片生成配置
# ========================================

IMAGE_SIZE=512x512
IMAGE_QUALITY=standard
IMAGE_STYLES=realistic,artistic,cartoon,historical,fantasy

AI_IMAGE_PROVIDER=openai
AI_IMAGE_API_KEY=your_ai_image_api_key_here
AI_IMAGE_MODEL=dall-e-3
AI_IMAGE_BASE_URL=https://api.openai.com/v1

# ========================================
# 缓存配置（可选）
# ========================================

REDIS_URL=redis://localhost:6381

# ========================================
# 日志配置
# ========================================

LOG_LEVEL=info