# ─── 本地开发环境变量模板 ──────────────────────────────────────────
# 复制此文件为 .env.local 并填入真实值
# cp .env.local.example .env.local

# ─── AI 文本生成 API ─────────────────────────────────────────────
AI_API_KEY=ce430ccac8d44e8d9ee687f41fb242f9.Ns51A0Um3oH3TYcu
AI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
AI_MODEL=glm-5.1

# ─── AI 图片生成 API（OpenAI-compatible）─────────────────────────
# 支持 DALL-E、硅基流动、通义万相等 OpenAI-compatible 接口
AI_IMAGE_PROVIDER=openai          # openai | siliconflow | tongyi | custom
AI_IMAGE_API_KEY=ce430ccac8d44e8d9ee687f41fb242f9.Ns51A0Um3oH3TYcu
AI_IMAGE_MODEL=glm-image          # dall-e-3 | Kolors | wanx-v1 等
AI_IMAGE_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# ─── Next.js ─────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
