# 开发环境 Dockerfile
FROM node:18-bookworm-slim

# 设置工作目录
WORKDIR /app

# 安装必要的系统依赖（包括 OpenSSL 用于 Prisma）
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssl \
    ca-certificates \
    python3 \
    make \
    g++ && \
    rm -rf /var/lib/apt/lists/*

# 复制 package 文件
COPY package.json package-lock.json ./

# 安装开发依赖
RUN npm ci

# 复制源代码
COPY . .

# 生成 Prisma 客户端
RUN npx prisma generate

# 暴露端口
EXPOSE 3000

# 设置启动命令
CMD ["npm", "run", "dev"]